# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2 — URL pública del bucket (dominio personalizado o *.r2.dev)
VITE_R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# URL pública del sitio (usada para generar enlaces/QR de valoraciones).
# Si no se define, se usa https://andorra-viva.vercel.app por defecto.
VITE_PUBLIC_SITE_URL=https://andorra-viva.vercel.app

# Solo local: script npm run seed:test-users (nunca commitear la service role)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 — credenciales para scripts de seed y Edge Function `r2-upload-url`
# (Supabase → Edge Functions → Secrets)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=business-images
# R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# Stripe (Edge Functions en Supabase — nunca en el frontend)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_PREMIUM=price_...
# PUBLIC_SITE_URL=https://andorra-viva.vercel.app
# Opcional: SEED_TEST_USER_PASSWORD=TestUser123!
# SEED_USER_COUNT=10
# SEED_VISIT_COUNT=50
# npm run seed:businesses — descarga fotos + 12 negocios (2 por categoría) en usuarios test
# npm run seed:assets — solo descarga fotos a scripts/seed-assets/
